# Example environment variables for {{bot_id}}.
# Copy this file to .env and fill in real values before running the bot outside
# Docker Compose. Do not commit real secrets to version control.

# Logging level for the bot handler: debug, info, warn, or error.
PACTO_LOG_LEVEL=info

# Transport used to reach the daemon: unix, http, or auto.
PACTO_TRANSPORT=auto

# Data directory used by the SDK to resolve socket paths and runtime state.
PACTO_DATA_DIR=...

# Shared secret token for HTTP transport authentication. Generate a random
# string of at least 32 characters and export it here (or pass --secret).
PACTO_SECRET_TOKEN=...
